# BRE Builders — Environment Variables
# Copy this to .env.local for local dev
# Add ALL variables to Vercel dashboard (never commit .env.local)

# Email (Resend)
RESEND_API_KEY=re_[get from resend.com]
CONTACT_TO_EMAIL=brebuilders@gmail.com
CONTACT_CC_EMAILS=steve@brebuilders.com,[chris_full_email],[sean_full_email]

# Site
NEXT_PUBLIC_SITE_URL=https://brebuilders.com
NEXT_PUBLIC_GA_ID=G-[get from Google Analytics]

# Staging override (set automatically by Vercel for preview deployments)
# NEXT_PUBLIC_SITE_URL=https://brebuilders-website.vercel.app
