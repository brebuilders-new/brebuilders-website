# BRE Builders — Environment Variables
# Copy to .env.local for local dev
# Add ALL to Vercel dashboard → Settings → Environment Variables

# ─── Email (Resend) ─────────────────────────────────────
RESEND_API_KEY=re_[get from resend.com — free tier works]

# ─── Contact Routing ─────────────────────────────────────
# Production: full team routing
CONTACT_TO_EMAIL=brebuilders@gmail.com
CONTACT_CC_EMAILS=steve@brebuilders.com,chris@brebuilders.com,sean@brebuilders.com

# ─── Site ────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://brebuilders.com
NEXT_PUBLIC_GA_ID=G-[from Google Analytics — existing account]

# ─── Notes ───────────────────────────────────────────────
# In development (NODE_ENV=development), all emails go to:
#   ifyougetlockedout@protonmail.com
# No emails to internal team during testing — enforced in /api/contact/route.ts

# Supabase (BRE)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# OpenAI (for image vision analysis)
OPENAI_API_KEY=

# Admin auth (simple password for /admin)
ADMIN_PASSWORD=bre2026steve
